# Python app
GAN_STUDIO_DEVICE=cpu
GAN_STUDIO_OUTPUT_DIR=outputs
GAN_STUDIO_CHECKPOINT_DIR=checkpoints

# Supabase public client values for local or remote development.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Backend-only secret. Never expose this value in browser/client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional remote provisioning values. scripts/provision-supabase.ts refuses to
# reuse an existing project and creates a new project name when these are set.
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORGANIZATION_ID=
SUPABASE_REGION=sa-east-1
SUPABASE_PROJECT_NAME_PREFIX=gan-image-studio
SUPABASE_DB_PASSWORD=

# Optional verification values after provisioning.
SUPABASE_PROJECT_REF=
